      "key": "variableCityRunSave",
      "file": "variable-city-variableCityRunSave.json",
      "label": "Run checkpoint",
      "cloud": true
    },
    {
      "key": "variableCitySettings",
      "file": "variable-city-variableCitySettings.json",
      "label": "Settings",
      "cloud": true
    },
    {
      "key": "variableCityAchievements",
      "file": "variable-city-variableCityAchievements.json",
