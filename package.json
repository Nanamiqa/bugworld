{
  "name": "variable-city-nightwatch",
  "version": "0.3.0",
  "private": true,
  "description": "A static Canvas roguelike demo with a GitHub Pages web build and a Steam-ready desktop shell.",
  "main": "desktop/electron/main.cjs",
  "scripts": {
    "check": "node --check src/main.js && node --check src/data/game-data.js && node --check src/platform/web-platform.js && node --check desktop/electron/main.cjs && node --check desktop/electron/preload.cjs && node desktop/tools/check-steam-cloud-layout.cjs",
    "check:cloud": "node desktop/tools/check-steam-cloud-layout.cjs",
    "desktop": "electron .",
    "dist:win": "electron-builder --win dir"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.nanamiqa.variablecity.nightwatch",
    "productName": "变量城夜巡",
    "copyright": "Copyright © 2026 NanamiQA",
    "asar": true,
    "directories": {
      "output": "dist/steam-demo"
    },
    "files": [
      "index.html",
      "src/**/*",
      "desktop/electron/**/*",
      "desktop/steam/**/*",
      "README.md",
      "docs/steam-release-plan.md",
      "docs/world-bible.md",
      "docs/design/**/*",
      "docs/art/**/*"
    ],
    "extraMetadata": {
      "main": "desktop/electron/main.cjs"
    },
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
